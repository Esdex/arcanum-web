---
import ScreenshotGallery from './ScreenshotGallery';
---

<section id="screenshots" class="py-28">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16 px-5">
      <p class="text-xs tracking-[0.2em] uppercase font-semibold text-crystal mb-4">Interface</p>
      <h2 class="text-3xl sm:text-4xl font-bold mb-5 tracking-tight">
        Beautiful by design
      </h2>
      <p class="text-gray-400 max-w-md mx-auto leading-relaxed">
        A vault that's as elegant as it is secure. Security tools don't have to be ugly.
      </p>
    </div>

    <ScreenshotGallery client:visible />

    <p class="text-center text-gray-700 text-xs mt-10 px-5">
      UI mockups — real screenshots coming soon
    </p>
  </div>
</section>
