---
---

<header class="fixed top-0 left-0 right-0 z-50">
  <div class="bg-[#0A0A0A]/75 backdrop-blur-xl border-b border-white/[0.05]">
    <div class="max-w-6xl mx-auto px-5 py-4 flex justify-between items-center">
      <a href="/" class="flex items-center gap-2.5 group">
        <img src="/logo.svg" alt="Arcanum" class="w-7 h-7" />
        <span class="font-bold text-white tracking-tight">Arcanum</span>
      </a>

      <nav class="flex items-center gap-6 text-sm">
        <a href="/#features" class="text-gray-400 hover:text-white transition-colors hidden sm:block">Features</a>
        <a href="/#screenshots" class="text-gray-400 hover:text-white transition-colors hidden sm:block">Screenshots</a>
        <a href="/#download" class="text-gray-400 hover:text-white transition-colors hidden sm:block">Download</a>
        <a href="/docs" class="text-gray-400 hover:text-white transition-colors hidden sm:block">Docs</a>
        <a
          href="https://github.com/Esdex/Arcanum"
          class="flex items-center gap-1.5 px-4 py-2 bg-white/[0.06] border border-white/10 rounded-lg text-white hover:bg-white/10 transition-colors font-medium hidden sm:flex"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
          </svg>
          GitHub
        </a>

        <!-- Hamburger button (mobile only) -->
        <button
          id="nav-menu-toggle"
          class="sm:hidden flex items-center justify-center w-9 h-9 rounded-lg bg-white/[0.06] border border-white/10 text-white hover:bg-white/10 transition-colors"
          aria-label="Open menu"
          aria-expanded="false"
        >
          <svg id="nav-icon-menu" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
          <svg id="nav-icon-close" class="w-5 h-5 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </nav>
    </div>
  </div>

  <!-- Mobile dropdown menu -->
  <div
    id="nav-mobile-menu"
    class="sm:hidden hidden bg-[#0A0A0A]/95 backdrop-blur-xl border-b border-white/[0.05]"
  >
    <nav class="max-w-6xl mx-auto px-5 py-4 flex flex-col gap-1">
      <a href="/#features"    class="px-3 py-2.5 rounded-lg text-gray-400 hover:text-white hover:bg-white/[0.04] transition-colors text-sm">Features</a>
      <a href="/#screenshots" class="px-3 py-2.5 rounded-lg text-gray-400 hover:text-white hover:bg-white/[0.04] transition-colors text-sm">Screenshots</a>
      <a href="/#download"    class="px-3 py-2.5 rounded-lg text-gray-400 hover:text-white hover:bg-white/[0.04] transition-colors text-sm">Download</a>
      <a href="/docs"         class="px-3 py-2.5 rounded-lg text-gray-400 hover:text-white hover:bg-white/[0.04] transition-colors text-sm">Docs</a>
      <a href="https://github.com/Esdex/Arcanum" class="px-3 py-2.5 rounded-lg text-gray-400 hover:text-white hover:bg-white/[0.04] transition-colors text-sm flex items-center gap-2">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
        </svg>
        GitHub
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle  = document.getElementById('nav-menu-toggle');
  const menu    = document.getElementById('nav-mobile-menu');
  const iconMenu  = document.getElementById('nav-icon-menu');
  const iconClose = document.getElementById('nav-icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    iconMenu?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });

  // Close menu when a link is clicked
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      iconMenu?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
