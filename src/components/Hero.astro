---
import HeroLogo from './HeroLogo';
---

<section class="relative min-h-screen flex flex-col items-center justify-center text-center px-5 overflow-hidden pt-16">
  <!-- Background atmosphere -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div
      class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[700px] rounded-full"
      style="background: radial-gradient(circle, rgba(156,39,176,0.12) 0%, transparent 62%);"
    />
    <div
      class="absolute bottom-0 left-1/4 w-[500px] h-[500px] rounded-full"
      style="background: radial-gradient(circle, rgba(58,166,174,0.08) 0%, transparent 60%);"
    />
    <div
      class="absolute inset-0 opacity-[0.025]"
      style="background-image: linear-gradient(rgba(255,255,255,0.6) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.6) 1px, transparent 1px); background-size: 64px 64px;"
    />
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-4xl mx-auto">
    <!-- Animated logo -->
    <div class="mb-8">
      <HeroLogo client:load />
    </div>

    <!-- Wordmark -->
    <h1 class="text-6xl sm:text-7xl lg:text-8xl font-black tracking-tight mb-5">
      Arcanum
    </h1>

    <!-- Primary tagline -->
    <p
      class="text-xl sm:text-2xl font-semibold mb-5"
      style="background: linear-gradient(135deg, #3aa6ae, #67c0b6); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
    >
      VeraCrypt-compatible encrypted vault for Android
    </p>

    <!-- Secondary tagline -->
    <p class="text-gray-400 text-base sm:text-lg max-w-md mx-auto leading-relaxed">
      Open source. No compromises.<br />Your data, perfectly hidden.
    </p>

  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-3 text-gray-600">
    <span class="text-[10px] tracking-[0.2em] uppercase font-medium">Scroll</span>
    <div class="w-px h-10 bg-gradient-to-b from-gray-600 to-transparent animate-scroll-line" />
  </div>
</section>
