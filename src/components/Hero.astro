---
import HeroLogo from './HeroLogo';
---

<section class="relative min-h-screen flex flex-col items-center justify-center text-center px-5 overflow-hidden pt-16">
  <!-- Background atmosphere -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div
      class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[700px] rounded-full"
      style="background: radial-gradient(circle, rgba(156,39,176,0.12) 0%, transparent 62%);"
    />
    <div
      class="absolute bottom-0 left-1/4 w-[500px] h-[500px] rounded-full"
      style="background: radial-gradient(circle, rgba(58,166,174,0.08) 0%, transparent 60%);"
    />
    <div
      class="absolute inset-0 opacity-[0.025]"
      style="background-image: linear-gradient(rgba(255,255,255,0.6) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.6) 1px, transparent 1px); background-size: 64px 64px;"
    />
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-4xl mx-auto">
    <!-- Animated logo -->
    <div class="mb-8">
      <HeroLogo client:load />
    </div>

    <!-- Wordmark -->
    <h1 class="text-6xl sm:text-7xl lg:text-8xl font-black tracking-tight mb-5">
      Arcanum
    </h1>

    <!-- Primary tagline -->
    <p
      class="text-xl sm:text-2xl font-semibold mb-5"
      style="background: linear-gradient(135deg, #3aa6ae, #67c0b6); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
    >
      VeraCrypt-compatible encrypted vault for Android
    </p>

    <!-- Secondary tagline -->
    <p class="text-gray-400 text-base sm:text-lg max-w-md mx-auto mb-12 leading-relaxed">
      Open source. No compromises.<br />Your data, perfectly hidden.
    </p>

    <!-- CTA buttons -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
      <a
        href="https://f-droid.org/"
        class="inline-flex items-center justify-center gap-2.5 px-8 py-4 rounded-2xl font-bold text-[#0A0A0A] text-sm transition-all hover:scale-[1.03] active:scale-[0.98] shadow-lg shadow-crystal/20"
        style="background: linear-gradient(135deg, #3aa6ae, #67c0b6);"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12.012 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75-4.365-9.75-9.75-9.75zm-1.186 13.5V8.25l6.375 3.75-6.375 3.75z" />
        </svg>
        Get on F-Droid
      </a>
      <a
        href="https://github.com/"
        class="inline-flex items-center justify-center gap-2.5 px-8 py-4 rounded-2xl font-bold text-white text-sm bg-white/[0.06] border border-white/10 hover:bg-white/10 transition-all active:scale-[0.98]"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
        </svg>
        View on GitHub
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-3 text-gray-600">
    <span class="text-[10px] tracking-[0.2em] uppercase font-medium">Scroll</span>
    <div class="w-px h-10 bg-gradient-to-b from-gray-600 to-transparent animate-scroll-line" />
  </div>
</section>
