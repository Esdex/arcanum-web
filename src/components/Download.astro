---
---

<section id="download" class="py-28 px-5">
  <div class="max-w-3xl mx-auto text-center">
    <p class="text-xs tracking-[0.2em] uppercase font-semibold text-crystal mb-4">Get the app</p>
    <h2 class="text-3xl sm:text-4xl font-bold mb-5 tracking-tight">Download Arcanum</h2>
    <p class="text-gray-400 mb-14 leading-relaxed">Free and open source. Always. No strings attached.</p>

    <div class="flex flex-col sm:flex-row gap-5 justify-center">
      <!-- F-Droid -->
      <a
        href="https://f-droid.org/"
        class="group flex flex-col items-center gap-4 bg-[#141414] border border-white/[0.07] rounded-2xl p-8 hover:border-crystal/40 transition-all duration-300 hover:bg-[#181818]"
      >
        <div
          class="w-14 h-14 rounded-2xl flex items-center justify-center transition-colors"
          style="background: rgba(58,166,174,0.12);"
        >
          <svg class="w-7 h-7 text-crystal" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12.012 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75-4.365-9.75-9.75-9.75zm-1.186 13.5V8.25l6.375 3.75-6.375 3.75z" />
          </svg>
        </div>
        <div>
          <p class="text-xs text-gray-500 mb-0.5">Available on</p>
          <p class="font-bold text-lg text-white">F-Droid</p>
        </div>
        <span class="text-xs text-crystal font-medium">No tracking · No ads →</span>
      </a>

      <!-- GitHub Releases -->
      <a
        href="https://github.com/"
        class="group flex flex-col items-center gap-4 bg-[#141414] border border-white/[0.07] rounded-2xl p-8 hover:border-white/25 transition-all duration-300 hover:bg-[#181818]"
      >
        <div class="w-14 h-14 rounded-2xl bg-white/[0.06] flex items-center justify-center transition-colors">
          <svg class="w-7 h-7 text-white" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
          </svg>
        </div>
        <div>
          <p class="text-xs text-gray-500 mb-0.5">Direct APK from</p>
          <p class="font-bold text-lg text-white">GitHub Releases</p>
        </div>
        <span class="text-xs text-gray-500 font-medium">Latest release →</span>
      </a>
    </div>

    <p class="mt-8 text-gray-700 text-xs">Google Play Store — coming soon</p>
  </div>
</section>
