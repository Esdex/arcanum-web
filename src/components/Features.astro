---
import FeatureCards from './FeatureCards';
---

<section id="features" class="py-28 px-5">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <p class="text-xs tracking-[0.2em] uppercase font-semibold text-crystal mb-4">Capabilities</p>
      <h2 class="text-3xl sm:text-4xl font-bold mb-5 tracking-tight">
        Encryption without compromise
      </h2>
      <p class="text-gray-400 max-w-lg mx-auto leading-relaxed">
        Military-grade cryptography built for everyday Android life. Because privacy shouldn't require a PhD.
      </p>
    </div>

    <FeatureCards client:visible />
  </div>
</section>
